# ── YatraBeyond environment variables ──────────────────────────────────────
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to source control.

# Site URL used for absolute URLs in metadata, sitemap, and RSS.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.yatrabeyond.com

# Optional: analytics ID (wire up your own provider; none included by default)
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: future CMS API key (not used in Phase 1 – content is MDX files)
# CONTENT_API_URL=
# CONTENT_API_KEY=

# ── Postgres (yatrabeyond content DB) ──────────────────────────────────────
# The database lives on the droplet, Postgres 16, bound to localhost only.
# In dev, open an SSH tunnel first (see web/.env for the exact command), then
# point these at 127.0.0.1:5432. Real values live in web/.env (gitignored).
# DATABASE_URL=postgresql://yatrabeyond_app:PASSWORD@127.0.0.1:5432/yatrabeyond
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=yatrabeyond
# PGUSER=yatrabeyond_app
# PGPASSWORD=
